# Embedding mode: "api" (OpenRouter) or "local" (local Qwen model)
# Auto-detected: api if OPENROUTER_KEY is set, otherwise local
# EMBEDDING_MODE=api

# OpenRouter API Key (required for api mode)
# OPENROUTER_KEY=your_key_here

# Local embedding model (for local mode, default: Qwen/Qwen3-Embedding-4B)
# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B

# GPU device
DEVICE=cuda:0

# Server port
GRADIO_SERVER_PORT=8811
